APP_NAME="SQB Agent Copilot"
FRONTEND_ORIGIN="http://localhost:5173"

# AI tahlil
AI_PROVIDER="rules"
AI_FALLBACK_TO_RULES=true
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
OPENAI_TIMEOUT_SECONDS=30

# Aisha AI STT/TTS
AISHA_API_KEY=""
AISHA_API_BASE_URL="https://back.aisha.group"
AISHA_STT_PATH="/api/v2/stt/post/"
AISHA_STT_RESULT_PATH="/api/v2/stt/get/{id}/"
AISHA_TTS_PATH="/api/v1/tts/post/"
AISHA_TTS_STATUS_PATH="/api/v1/tts/status/{id}/"
AISHA_LANGUAGE="uz"
AISHA_TTS_MODEL="gulnoza"
AISHA_STT_HAS_DIARIZATION=false
AISHA_POLL_ATTEMPTS=12
AISHA_POLL_INTERVAL_SECONDS=2

# Wasabi S3-compatible storage
WASABI_ENDPOINT_URL="https://s3.eu-central-1.wasabisys.com"
WASABI_REGION="eu-central-1"
WASABI_BUCKET=""
WASABI_ACCESS_KEY_ID=""
WASABI_SECRET_ACCESS_KEY=""
WASABI_PUBLIC_BASE_URL=""
